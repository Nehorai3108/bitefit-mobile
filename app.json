{
  "expo": {
    "name": "BiteFit",
    "slug": "bitefit-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nehorai3108.bitefit",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.nehorai3108.bitefit",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-barcode-scanner",
      "expo-image-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "bitefit-mobile"
      }
    }
  }
}
